<section id="timeline" class="bg-white dark:bg-neutral-950 py-20 px-4 md:px-8">
  <div class="max-w-7xl mx-auto">
    <h2 class="text-2xl md:text-4xl font-bold mb-6 text-black dark:text-white max-w-4xl" data-i18n="journey.title">
      So funktioniert’s
