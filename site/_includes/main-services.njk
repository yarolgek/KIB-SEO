{# Optional: sectionId, compact (bool) #}
{% set _id = sectionId or "leistungen" %}
<section id="{{ _id }}" class="{% if compact %}py-12{% else %}py-16{% endif %} px-4 md:px-8 max-w-7xl mx-auto">
