<footer class="border-t border-gray-200 dark:border-gray-800 pt-16 pb-12 px-4 md:px-8">
  <div class="max-w-7xl mx-auto">

    {# —— Schnelllinks & Kontakt —— #}
    <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-10 mb-12">
      <div>
        <p class="text-sm font-bold text-gray-900 dark:text-white mb-4" data-i18n="footer.quickLinks">Schnelllinks</p>
        <ul class="space-y-2.5 text-sm text-gray-500 dark:text-gray-400">
          <li><a href="/" class="hover:text-gray-900 dark:hover:text-white transition-colors" data-i18n="nav.home">Startseite</a></li>
          <li><a href="/ueber-uns/" class="hover:text-gray-900 dark:hover:text-white transition-colors" data-i18n="nav.about">Über uns</a></li>
          <li><a href="/#services" class="hover:text-gray-900 dark:hover:text-white transition-colors" data-i18n="nav.services">Dienstleistungen</a></li>
          <li><a href="/regionen/" class="hover:text-gray-900 dark:hover:text-white transition-colors" data-i18n="nav.regions">Regionen</a></li>
          <li><a href="/kontakt/" class="hover:text-gray-900 dark:hover:text-white transition-colors" data-i18n="nav.contact">Kontakt</a></li>
          <li><a href="/impressum/" class="hover:text-gray-900 dark:hover:text-white transition-colors" data-i18n="footer.imprint">Impressum</a></li>
          <li><a href="/datenschutz/" class="hover:text-gray-900 dark:hover:text-white transition-colors" data-i18n="footer.privacy">Datenschutz</a></li>
        </ul>
      </div>
      <div>
        <p class="text-sm font-bold text-gray-900 dark:text-white mb-4" data-i18n="footer.contact">Kontakt</p>
        <address class="not-italic space-y-2.5 text-sm text-gray-500 dark:text-gray-400">
          <p class="font-medium text-gray-900 dark:text-white">{{ site.name }}</p>
          <p>{{ site.address.street }}</p>
          <p>{{ site.address.postalCode }} {{ site.address.city }}</p>
          <p><a href="tel:{{ site.phone | replace(' ', '') }}" class="hover:text-gray-900 dark:hover:text-white transition-colors">{{ site.phone }}</a></p>
          <p><a href="mailto:{{ site.email }}" class="hover:text-gray-900 dark:hover:text-white transition-colors">{{ site.email }}</a></p>
        </address>
      </div>
    </div>

    {# —— Dienstleistungen —— #}
    <div class="border-t border-gray-200 dark:border-gray-800 pt-12 mb-12">
      <p class="text-lg font-bold text-gray-900 dark:text-white mb-8" data-i18n="footer.services">Dienstleistungen</p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-12">
        <div>
          <p class="text-xs font-bold uppercase tracking-wide text-gray-900 dark:text-white mb-4" data-i18n="footer.cat.seo">SEO &amp; Lokal</p>
          <ul class="space-y-2.5 text-sm text-gray-500 dark:text-gray-400">
            <li><a href="/local-seo/" class="hover:text-gray-900 dark:hover:text-white transition-colors">Local SEO</a></li>
            <li><a href="/seo/" class="hover:text-gray-900 dark:hover:text-white transition-colors">SEO</a></li>
            <li><a href="/geo-aeo/" class="hover:text-gray-900 dark:hover:text-white transition-colors">GEO &amp; AEO</a></li>
            <li><a href="/seo-services/" class="hover:text-gray-900 dark:hover:text-white transition-colors">SEO Services</a></li>
            <li><a href="/seo-analyse/" class="hover:text-gray-900 dark:hover:text-white transition-colors">SEO Analyse</a></li>
            <li><a href="/google-maps-optimierung/" class="hover:text-gray-900 dark:hover:text-white transition-colors">Google Maps Optimierung</a></li>
            <li><a href="/google-business-profile/" class="hover:text-gray-900 dark:hover:text-white transition-colors">Google Business Profile</a></li>
          </ul>
        </div>
        <div>
          <p class="text-xs font-bold uppercase tracking-wide text-gray-900 dark:text-white mb-4" data-i18n="footer.cat.website">Website &amp; Design</p>
          <ul class="space-y-2.5 text-sm text-gray-500 dark:text-gray-400">
            <li><a href="/website-erstellung/" class="hover:text-gray-900 dark:hover:text-white transition-colors">Website Erstellung</a></li>
            <li><a href="/website-optimierung/" class="hover:text-gray-900 dark:hover:text-white transition-colors">Website Optimierung</a></li>
            <li><a href="/landing-page-design/" class="hover:text-gray-900 dark:hover:text-white transition-colors">Landing Page Design</a></li>
          </ul>
        </div>
        <div>
          <p class="text-xs font-bold uppercase tracking-wide text-gray-900 dark:text-white mb-4" data-i18n="footer.cat.ads">Ads &amp; Marketing</p>
          <ul class="space-y-2.5 text-sm text-gray-500 dark:text-gray-400">
            <li><a href="/google-ads/" class="hover:text-gray-900 dark:hover:text-white transition-colors">Google Ads Management</a></li>
            <li><a href="/facebook-ads/" class="hover:text-gray-900 dark:hover:text-white transition-colors">Facebook Ads</a></li>
            <li><a href="/meta-ads/" class="hover:text-gray-900 dark:hover:text-white transition-colors">Meta Ads</a></li>
            <li><a href="/digitale-werbung/" class="hover:text-gray-900 dark:hover:text-white transition-colors">Digitale Werbung</a></li>
            <li><a href="/search-engine-marketing/" class="hover:text-gray-900 dark:hover:text-white transition-colors">Search Engine Marketing</a></li>
            <li><a href="/email-marketing/" class="hover:text-gray-900 dark:hover:text-white transition-colors">Email Marketing</a></li>
            <li><a href="/ads/" class="hover:text-gray-900 dark:hover:text-white transition-colors">Online Marketing</a></li>
          </ul>
        </div>
        <div>
          <p class="text-xs font-bold uppercase tracking-wide text-gray-900 dark:text-white mb-4" data-i18n="footer.cat.growth">Conversion &amp; KI</p>
          <ul class="space-y-2.5 text-sm text-gray-500 dark:text-gray-400">
            <li><a href="/ai/" class="hover:text-gray-900 dark:hover:text-white transition-colors">KI Lösungen</a></li>
            <li><a href="/lead-generierung/" class="hover:text-gray-900 dark:hover:text-white transition-colors">Lead Generierung</a></li>
            <li><a href="/conversion-optimierung/" class="hover:text-gray-900 dark:hover:text-white transition-colors">Conversion Optimierung</a></li>
            <li><a href="/web-analyse-setup/" class="hover:text-gray-900 dark:hover:text-white transition-colors">Web Analyse Setup</a></li>
          </ul>
        </div>
      </div>
    </div>

    {# —— Regionen —— #}
    <div class="border-t border-gray-200 dark:border-gray-800 pt-12 mb-12">
      <p class="text-lg font-bold text-gray-900 dark:text-white mb-8" data-i18n="nav.regions">Regionen</p>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-x-8 gap-y-2.5 text-sm text-gray-500 dark:text-gray-400">
        <a href="/regionen/" class="hover:text-gray-900 dark:hover:text-white transition-colors" data-i18n="footer.allRegions">Alle Regionen</a>
        {% for area in regions %}
        <a href="{{ area.href }}" class="hover:text-gray-900 dark:hover:text-white transition-colors">{{ area.label }}</a>
        {% endfor %}
      </div>
    </div>

    <p class="border-t border-gray-200 dark:border-gray-800 pt-8 text-center text-sm text-gray-500 dark:text-gray-400">© 2026 KI Brueder.</p>

  </div>
</footer>
