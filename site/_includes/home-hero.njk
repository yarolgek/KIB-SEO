<section class="relative min-h-screen flex items-center overflow-hidden bg-white dark:bg-neutral-950 pt-32 pb-20">
  <!-- Background glow -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
    <div class="absolute w-[500px] h-[500px] blur-[120px] rounded-full bg-gradient-to-r from-yellow-500/20 to-orange-500/20 -top-64 -right-64 opacity-60 dark:opacity-100 hero-glow"></div>
    <div class="absolute w-[500px] h-[500px] blur-[120px] rounded-full bg-gradient-to-r from-orange-500/20 to-yellow-500/20 -bottom-64 -left-64 opacity-60 dark:opacity-100 hero-glow hero-glow-delay"></div>
  </div>

  <!-- Lightweight flowing lines (CSS transform only — GPU friendly) -->
  <div class="hero-lines absolute inset-0 pointer-events-none text-slate-950/40 dark:text-white/35" aria-hidden="true">
    <svg class="hero-lines-layer hero-lines-a absolute inset-0 w-full h-full" viewBox="0 0 696 316" fill="none" preserveAspectRatio="xMidYMid slice">
      <path d="M-360 -180C-360 -180 -292 210 172 337C636 464 704 869 704 869" stroke="currentColor" stroke-width="1.1" />
      <path d="M-340 -162C-340 -162 -272 198 192 325C656 452 724 851 724 851" stroke="currentColor" stroke-width="0.95" opacity="0.85" />
      <path d="M-320 -144C-320 -144 -252 186 212 313C676 440 744 833 744 833" stroke="currentColor" stroke-width="0.85" opacity="0.7" />
      <path d="M-300 -126C-300 -126 -232 174 232 301C696 428 764 815 764 815" stroke="currentColor" stroke-width="0.75" opacity="0.55" />
      <path d="M-280 -108C-280 -108 -212 162 252 289C716 416 784 797 784 797" stroke="currentColor" stroke-width="0.65" opacity="0.4" />
      <path d="M-260 -90C-260 -90 -192 150 272 277C736 404 804 779 804 779" stroke="currentColor" stroke-width="0.55" opacity="0.3" />
    </svg>
    <svg class="hero-lines-layer hero-lines-b absolute inset-0 w-full h-full" viewBox="0 0 696 316" fill="none" preserveAspectRatio="xMidYMid slice">
      <path d="M-400 -198C-400 -198 -332 228 132 355C596 482 664 887 664 887" stroke="currentColor" stroke-width="1.05" />
      <path d="M-380 -180C-380 -180 -312 210 152 337C616 464 684 869 684 869" stroke="currentColor" stroke-width="0.9" opacity="0.8" />
      <path d="M-360 -162C-360 -162 -292 198 172 325C636 452 704 851 704 851" stroke="currentColor" stroke-width="0.8" opacity="0.65" />
      <path d="M-340 -144C-340 -144 -272 186 192 313C656 440 724 833 724 833" stroke="currentColor" stroke-width="0.7" opacity="0.5" />
      <path d="M-320 -126C-320 -126 -252 174 212 301C676 428 744 815 744 815" stroke="currentColor" stroke-width="0.6" opacity="0.35" />
    </svg>
  </div>

  <div class="relative z-10 container mx-auto px-4 md:px-8">
    <div class="max-w-4xl">
      <h1 class="text-5xl md:text-7xl font-bold tracking-tight mb-6">
        <span class="block text-gray-900 dark:text-gray-200 hero-fade" data-i18n="hero.growth">Mehr Kunden über Google.</span>
        <span class="block text-gray-900 dark:text-gray-200 hero-fade hero-fade-delay-1" data-i18n="hero.headaches">Weniger Stress.</span>
        <span class="bg-gradient-to-r from-yellow-500 to-orange-500 text-transparent bg-clip-text hero-fade hero-fade-delay-2" data-i18n="hero.guaranteed">Garantiert.</span>
      </h1>
      <p class="text-xl md:text-2xl text-gray-600 dark:text-gray-300 mb-10 max-w-2xl leading-relaxed hero-fade hero-fade-delay-3" data-i18n="hero.explainer">
        Wir bringen Ihr Unternehmen bei Google nach vorne – und füllen Ihren Kalender mit Anfragen.
      </p>

      <div class="flex flex-wrap gap-6 hero-fade hero-fade-delay-4">
        <a href="/kontakt/" class="bg-gradient-to-r from-yellow-500 to-orange-500 hover:from-yellow-600 hover:to-orange-600 text-white px-8 py-4 rounded-lg font-semibold transition-all" data-i18n="hero.cta.book">
          Kostenloses Gespräch (30 Min.)
        </a>
        <a href="/#timeline" class="text-gray-600 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white flex items-center gap-2 px-8 py-4 transition-colors" data-i18n="hero.cta.services">
          So funktioniert’s
          {% include "icons/arrow-right.njk" %}
        </a>
      </div>
    </div>
  </div>
</section>
