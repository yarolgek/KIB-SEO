<a href="{{ cardHref }}" class="group bg-white dark:bg-gray-900 rounded-2xl overflow-hidden border border-gray-200 dark:border-gray-800 hover:border-yellow-500/50 dark:hover:border-yellow-500/50 transition-all duration-300 hover:shadow-[0_0_30px_rgba(234,179,8,0.2)] dark:hover:shadow-[0_0_30px_rgba(234,179,8,0.1)] relative block">
  <div class="absolute inset-0 bg-gradient-to-br from-yellow-500/[0.05] to-orange-500/[0.05] dark:from-yellow-500/[0.02] dark:to-orange-500/[0.02] opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
  <img
    src="{{ cardImage }}"
    alt="{{ cardImageAlt }}"
    class="w-full h-48 object-cover transition-transform duration-300 group-hover:scale-105"
    loading="lazy"
    decoding="async"
  />
  <div class="p-6 relative">
    <h2 class="text-2xl font-bold mb-2 group-hover:text-yellow-500 dark:group-hover:text-yellow-400 transition-colors duration-300">{{ cardTitle }}</h2>
    <div class="flex items-center gap-4 text-gray-600 dark:text-gray-400 text-sm mb-4">
      <span>{{ cardAuthor }}</span>
      <span>•</span>
      <span>{{ cardDate }}</span>
      <span>•</span>
      <span>{{ cardReadTime }}</span>
    </div>
    <p class="text-gray-600 dark:text-gray-400 mb-6 group-hover:text-gray-900 dark:group-hover:text-gray-200 transition-colors duration-300">{{ cardExcerpt }}</p>
    <span class="text-yellow-600 dark:text-yellow-400 group-hover:text-yellow-700 dark:group-hover:text-yellow-300 font-semibold inline-flex items-center gap-2 transition-all group-hover:gap-3"><span data-i18n="blog.readMore">Weiterlesen</span> →</span>
  </div>
</a>
